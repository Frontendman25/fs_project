# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — dependencies
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — development
# Used by docker-compose.dev.yml. Source code is bind-mounted at runtime.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS development
WORKDIR /app

ENV NODE_ENV=development

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN chown -R appuser:appgroup /app

USER appuser
EXPOSE 3000

CMD ["npm", "run", "dev"]

# ─────────────────────────────────────────────────────────────────────────────
# Stage 3 — builder
# Compiles the Next.js app with standalone output enabled.
# NEXT_PUBLIC_* vars must be provided as build-args here because Next.js
# inlines them at build time (they are not available at runtime).
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=http://localhost:3100
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 4 — production
# Lean image using Next.js standalone output.
# The standalone server bundles only the server-side code and its dependencies.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS production
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Standalone output — includes server.js and a minimal node_modules tree.
COPY --from=builder --chown=appuser:appgroup /app/.next/standalone ./
# Static assets must be copied alongside the standalone server.
COPY --from=builder --chown=appuser:appgroup /app/.next/static ./.next/static
COPY --from=builder --chown=appuser:appgroup /app/public ./public

USER appuser
EXPOSE 3000

# server.js is generated by Next.js standalone output.
CMD ["node", "server.js"]
