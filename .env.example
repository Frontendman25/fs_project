# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=development              # development | production | test

# ── Database selection ───────────────────────────────────────────────────────
# Which database the backend should use.
DATABASE_TYPE=postgresql          # postgresql | mongodb

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by Prisma and by the PostgreSQL database container.
# In Docker the hostname is the service name: 'postgres'
POSTGRES_USER=fs_project
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fs_project
# Host port for local Postgres (docker-compose.dev.yml maps POSTGRES_PORT:5432)
POSTGRES_PORT=5434
# Which DB the dev Docker backend uses: local | neon | auto (auto = Neon if reachable)
DATABASE_TARGET=local
# Production / Neon URL (not used when DATABASE_TARGET=local)
BACKEND_POSTGRESQL_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require
# Inside Docker Compose network (backend container → postgres service)
LOCAL_POSTGRESQL_URL=postgresql://fs_project:change_me@postgres:5432/fs_project
# Host tools: Prisma Studio, npm run dev on the machine (not inside Docker)
POSTGRESQL_URL=postgresql://fs_project:change_me@localhost:5434/fs_project
# Non-pooler URL for Prisma migrations (optional). If unset and POSTGRESQL_URL uses Neon "-pooler.",
# backend/scripts/start.sh derives it; otherwise it defaults to POSTGRESQL_URL.
# POSTGRESQL_DIRECT_URL=postgresql://user:password@your-neon-direct-host.neon.tech/neondb?sslmode=require
# Render / Neon often provide DATABASE_URL; backend/scripts/start.sh maps it to POSTGRESQL_URL if needed.
# DATABASE_URL=

# ── MongoDB ──────────────────────────────────────────────────────────────────
# In Docker the hostname is the service name: 'mongodb'
MONGO_USER=fs_project
MONGO_PASSWORD=change_me
MONGO_DB=fs_project
MONGODB_URI=mongodb://fs_project:change_me@mongodb:27017/fs_project?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
# In Docker the hostname is the service name: 'redis'
REDIS_URL=redis://redis:6379

# ── Auth secrets ──────────────────────────────────────────────────────────────
# Use long random strings in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_use_64_random_hex_chars
REFRESH_TOKEN_SECRET=change_me_use_64_random_hex_chars
SESSION_SECRET=change_me_use_64_random_hex_chars

# JWT access TTL (jsonwebtoken `expiresIn`, e.g. 900, 15m, 12h, 7d)
ACCESS_TOKEN_EXPIRES_IN=12h
# Refresh token lifetime in days (DB expiresAt + httpOnly cookie maxAge)
REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Public URLs (CORS + JWT iss/aud) ─────────────────────────────────────────
# BACKEND_URL — public API base (JWT `iss`). Render often sets RENDER_EXTERNAL_URL instead.
# Example: https://your-api.onrender.com
BACKEND_URL=http://localhost:3100

# ── Frontend ──────────────────────────────────────────────────────────────────
# FRONTEND_URL — CORS, cookies, and JWT `aud` on access tokens (required in production).
FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL — browser API base (frontend); Compose passes into frontend image build.
# For local `npm run dev` in frontend/, prefer frontend/.env (see frontend/.env.example).
NEXT_PUBLIC_API_URL=http://localhost:3100

# ── Storage ───────────────────────────────────────────────────────────────────
# local  → files stored in LOCAL_STORAGE_PATH
# cloudinary → files stored on Cloudinary
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Required only when STORAGE_TYPE=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=uploads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug                   # trace | debug | info | warn | error
SQL_TRACE=false                   # true enables Prisma SQL query logging

# ── TubeLex / Render transcript probe (optional) ─────────────────────────────
# POST /api/debug/transcript with header x-debug-token
# DEBUG_TRANSCRIPT_TOKEN=change_me_long_random_string
# SUPADATA_API_KEY=your_supadata_key_for_fallback_probe
# YOUTUBE_TRANSCRIPT_PROXY_URL=http://USER:PASS@p.webshare.io:80
# Frontend (Vercel build): NEXT_PUBLIC_DEBUG_TRANSCRIPT_TOKEN=<same as DEBUG_TRANSCRIPT_TOKEN>

# ── Docker port overrides (optional) ─────────────────────────────────────────
# Override host-side ports when defaults conflict with other local services.
# BACKEND_PORT=3100
# FRONTEND_PORT=3000
# POSTGRES_PORT=5432
# MONGO_PORT=27017
# REDIS_PORT=6379
