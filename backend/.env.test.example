# Copy to `.env.test` and adjust. Used only by Vitest (see test/setup/loadEnv.ts).
# Never point this at production or shared dev databases.

NODE_ENV=test

# Prisma datasource (see prisma/schema.prisma — env name is POSTGRESQL_URL)
POSTGRESQL_URL=postgresql://postgres:postgres@localhost:5432/fs_backend_test

# Must match application bootstrap (use long random strings in real CI secrets)
JWT_SECRET=test-jwt-secret-at-least-32-characters-long!!
REFRESH_TOKEN_SECRET=test-refresh-secret-at-least-32-chars!!
SESSION_SECRET=test-session-secret-at-least-32-chars!!

DATABASE_TYPE=postgresql

# File uploads (avatar E2E uses local disk under this path)
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads-test
